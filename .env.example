# ==================================================
# BlueChain MRV — Environment Variables Template
# ==================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ==================================================

# Supabase project URL (from your Supabase project dashboard)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase publishable/anon key (safe for browser use — NOT the service role key)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase project ID (used for CLI and edge functions)
VITE_SUPABASE_PROJECT_ID=your-project-id

# ==================================================
# GEMINI API KEY — DO NOT ADD HERE
# ==================================================
# The GEMINI_API_KEY must NEVER appear in this file
# or any frontend code. It must only be set as a
# Supabase Edge Function secret via:
#
#   supabase secrets set GEMINI_API_KEY=your-key-here
#
# and accessed inside Edge Functions via:
#   Deno.env.get('GEMINI_API_KEY')
# ==================================================
